theme = dark:One Half Dark, light:One Half Light

font-family = MesloLGS NF
font-style = Regular
font-size = 16
font-thicken = true

cursor-style = block
cursor-style-blink = false

cursor-color = #ff0078
keybind = shift+enter=text:\n

keybind = cmd+r=prompt_surface_title

keybind = cmd+alt+h=goto_split:left
keybind = cmd+alt+j=goto_split:down
keybind = cmd+alt+k=goto_split:up
keybind = cmd+alt+l=goto_split:right

keybind = cmd+j=goto_split:next

keybind = cmd+shift+u=scroll_page_up
keybind = cmd+shift+d=scroll_page_down
keybind = cmd+shift+k=scroll_page_fractional:-0.1
keybind = cmd+shift+j=scroll_page_fractional:0.1
